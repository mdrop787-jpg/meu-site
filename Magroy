  <title>Magroy Genesis</title>
  <style>
    body {
      background-color: #000000;
      color: #FFFFFF;
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
    }
    header {
      background-color: #111111;
      padding: 20px;
      text-align: center;
    }
    nav a {
      color: #FFD700;
      margin: 0 15px;
      text-decoration: none;
      font-weight: bold;
    }
    nav a:hover {
      color: #00FF7F;
    }
    section {
      padding: 40px;
      text-align: center;
      border-bottom: 1px solid #333;
    }
    h2 {
      color: #FFD700;
    }
    button {
      background-color: #FFD700;
      border: none;
      padding: 10px 20px;
      color: #000;
      font-weight: bold;
      cursor: pointer;
    }
    button:hover {
