  <footer>
    <p>© 2026 Magroy Genesis | 
      <a href="https://www.magroy.com.br" style="color:#FFD700;">Loja Oficial</a> | 
      <a href="https://opensea.io" style="color:#00FF7F;">OpenSea</a>
    </p>
    <p>Siga-nos: Instagram | Twitter/X | Discord | YouTube</p>
  </footer>

  <script>
    // Cronômetro regressivo para pré-venda
    function startCountdown() {
      const targetDate = new Date("June 1, 2026 00:00:00").getTime();
      const timerElement = document.getElementById("timer");

      setInterval(function() {
        const now = new Date().getTime();
        const distance = targetDate - now;

        if (distance < 0) {
          timerElement.innerHTML = "Pré-venda iniciada!";
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        timerElement.innerHTML = days + "d " + hours + "h " + minutes + "m " + seconds + "s ";
      }, 1000);
    }
    startCountdown();
  </script>
</body>
</html>

